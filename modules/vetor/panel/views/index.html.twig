{% extends "module.html.twig" %}
{% block moduleContent %}
<div id="vetor-panel">
    <ul class="nav nav-tabs">
        <li class="active"><a href="#tab-widgets" data-toggle="tab">Widgets</a></li>
        <li><a href="#tab-rodape" data-toggle="tab">Rodapé / Notícias</a></li>
        <li><a href="#tab-arquivos" data-toggle="tab">Arquivos</a></li>
    </ul>
    <div class="tab-content">
        <div id="tab-widgets" class="tab-pane active">
            <div class="well well-sm" style="margin-top:10px">
                Configure os widgets exibidos na área de mídia do painel de senhas.
                Os widgets são exibidos em sequência (slideshow) na área principal do tema Vetor.
            </div>

            <div id="widgets-lista"></div>

            <div style="margin-top:15px">
                <div class="btn-group">
                    <button class="btn btn-success" onclick="VetorAdmin.adicionarWidget('video')">
                        <span class="glyphicon glyphicon-film"></span> Vídeo
                    </button>
                    <button class="btn btn-default" onclick="VetorAdmin.adicionarWidget('youtube')">
                        <span class="glyphicon glyphicon-play-circle"></span> YouTube
                    </button>
                    <button class="btn btn-default" onclick="VetorAdmin.adicionarWidget('iptv')">
                        <span class="glyphicon glyphicon-facetime-video"></span> IPTV
                    </button>
                    <button class="btn btn-info" onclick="VetorAdmin.adicionarWidget('image')">
                        <span class="glyphicon glyphicon-picture"></span> Imagem
                    </button>
                    <button class="btn btn-warning" onclick="VetorAdmin.adicionarWidget('html')">
                        <span class="glyphicon glyphicon-pencil"></span> HTML
                    </button>
                    <button class="btn btn-default" onclick="VetorAdmin.adicionarWidget('comunicado')">
                        <span class="glyphicon glyphicon-bullhorn"></span> Comunicado
                    </button>
                    <button class="btn btn-default" onclick="VetorAdmin.adicionarWidget('clima')">
                        <span class="glyphicon glyphicon-cloud"></span> Clima
                    </button>
                </div>
                <button class="btn btn-primary pull-right" onclick="VetorAdmin.salvar()">
                    <span class="glyphicon glyphicon-floppy-disk"></span> Salvar Configuração
                </button>
            </div>
        </div>

        <div id="tab-rodape" class="tab-pane">
            <div class="well well-sm" style="margin-top:10px">
                Configure os feeds RSS que serão exibidos no rodapé do painel (ticker de notícias).
                As notícias alternam automaticamente entre os feeds cadastrados.
            </div>

            <div id="news-sources-lista"></div>

            <div style="margin-top:15px">
                <button class="btn btn-default" onclick="VetorAdmin.adicionarFeed()">
                    <span class="glyphicon glyphicon-plus"></span> Adicionar Feed RSS
                </button>
                <button class="btn btn-primary pull-right" onclick="VetorAdmin.salvar()">
                    <span class="glyphicon glyphicon-floppy-disk"></span> Salvar Configuração
                </button>
            </div>

            <div class="form-group" style="margin-top:20px">
                <label>Intervalo entre notícias (ms)</label>
                <input type="number" class="form-control" style="width:200px"
                       value="" id="news-interval"
                       onchange="VetorAdmin.news.interval=parseInt(this.value)"
                       placeholder="10000">
                <p class="help-block">Tempo que cada notícia fica visível (padrão: 10000 = 10 segundos)</p>
            </div>
        </div>

        <div id="tab-arquivos" class="tab-pane">
            <div style="margin-top:10px">
                <form id="form-upload" enctype="multipart/form-data" onsubmit="return false">
                    <div class="form-group">
                        <label>Enviar arquivo (vídeo, imagem — máx. 200MB)</label>
                        <div class="input-group">
                            <input type="file" id="input-arquivo" name="arquivo" class="form-control"
                                   accept="video/*,image/*,audio/*">
                            <span class="input-group-btn">
                                <button class="btn btn-primary" onclick="VetorAdmin.upload()">
                                    <span class="glyphicon glyphicon-upload"></span> Enviar
                                </button>
                            </span>
                        </div>
                    </div>
                </form>
                <div id="upload-progresso" style="display:none">
                    <div class="progress">
                        <div class="progress-bar progress-bar-striped active" style="width:100%">Enviando...</div>
                    </div>
                </div>
            </div>
            <h4>Arquivos no servidor</h4>
            <table class="table table-striped" id="tabela-arquivos">
                <thead>
                    <tr><th>Nome</th><th>Tipo</th><th>Tamanho</th><th>URL</th><th></th></tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<script type="text/javascript">
var VetorAdmin = {
    widgets: {{ widgets|json_encode()|raw }},
    news: {{ news|json_encode()|raw }},

    tipoLabels: {
        'video': '<span class="glyphicon glyphicon-film"></span> VÍDEO',
        'youtube': '<span class="glyphicon glyphicon-play-circle"></span> YOUTUBE',
        'iptv': '<span class="glyphicon glyphicon-facetime-video"></span> IPTV',
        'image': '<span class="glyphicon glyphicon-picture"></span> IMAGEM',
        'html': '<span class="glyphicon glyphicon-pencil"></span> HTML',
        'comunicado': '<span class="glyphicon glyphicon-bullhorn"></span> COMUNICADO',
        'clima': '<span class="glyphicon glyphicon-cloud"></span> CLIMA'
    },

    renderizar: function() {
        var lista = $('#widgets-lista');
        lista.html('');
        for (var i = 0; i < VetorAdmin.widgets.length; i++) {
            var w = VetorAdmin.widgets[i];
            var label = VetorAdmin.tipoLabels[w.type] || w.type.toUpperCase();

            var card = '<div class="panel panel-default" data-index="' + i + '">';
            card += '<div class="panel-heading">';
            card += '<strong>#' + (i+1) + ' ' + label + '</strong>';
            card += ' — <input type="text" value="' + VetorAdmin.esc(w.title || '') + '" placeholder="Título" class="input-sm" onchange="VetorAdmin.widgets[' + i + '].title=this.value" style="width:200px">';
            card += ' <label style="margin-left:15px"><input type="checkbox" ' + (w.active ? 'checked' : '') + ' onchange="VetorAdmin.widgets[' + i + '].active=this.checked"> Ativo</label>';
            card += ' <button class="btn btn-xs btn-danger pull-right" onclick="VetorAdmin.removerWidget(' + i + ')"><span class="glyphicon glyphicon-trash"></span></button>';
            if (i > 0) card += ' <button class="btn btn-xs btn-default pull-right" style="margin-right:5px" onclick="VetorAdmin.moverWidget(' + i + ',-1)"><span class="glyphicon glyphicon-arrow-up"></span></button>';
            if (i < VetorAdmin.widgets.length - 1) card += ' <button class="btn btn-xs btn-default pull-right" style="margin-right:5px" onclick="VetorAdmin.moverWidget(' + i + ',1)"><span class="glyphicon glyphicon-arrow-down"></span></button>';
            card += '</div>';
            card += '<div class="panel-body">';

            // Campos específicos por tipo
            switch (w.type) {
                case 'video':
                case 'image':
                case 'audio':
                    card += VetorAdmin.campoUrl(i, w, 'URL do ' + w.type, 'http://... ou copie da aba Arquivos');
                    break;
                case 'youtube':
                    card += VetorAdmin.campoTexto(i, w, 'content', 'ID do vídeo YouTube', 'Ex: dQw4w9WgXcQ (parte final da URL)');
                    break;
                case 'iptv':
                    card += VetorAdmin.campoUrl(i, w, 'URL do stream IPTV', 'http://... (m3u8, ts, etc)');
                    break;
                case 'html':
                    card += '<div class="form-group"><label>Conteúdo HTML</label>';
                    card += '<textarea class="form-control" rows="4" onchange="VetorAdmin.widgets[' + i + '].content=this.value">' + VetorAdmin.esc(w.content || '') + '</textarea></div>';
                    break;
                case 'comunicado':
                    card += VetorAdmin.campoTexto(i, w, 'content', 'Texto do comunicado', 'Mensagem que será exibida no painel');
                    card += '<div class="row">';
                    card += '<div class="col-sm-4"><label>Cor do texto</label><input type="color" class="form-control" value="' + (w.textColor || '#FFFFFF') + '" onchange="VetorAdmin.widgets[' + i + '].textColor=this.value"></div>';
                    card += '<div class="col-sm-4"><label>Tamanho da fonte (vw)</label><input type="number" class="form-control" value="' + (w.fontSize || 4) + '" min="1" max="20" onchange="VetorAdmin.widgets[' + i + '].fontSize=parseInt(this.value)"></div>';
                    card += '</div>';
                    break;
                case 'clima':
                    card += VetorAdmin.campoTexto(i, w, 'cidade', 'Cidade', 'Ex: Salvador,BR ou São Paulo,BR');
                    card += '<p class="help-block">Usa a API gratuita do OpenWeatherMap. Informe a chave da API abaixo (obtenha em <a href="https://openweathermap.org/api" target="_blank">openweathermap.org</a>).</p>';
                    card += VetorAdmin.campoTexto(i, w, 'apiKey', 'Chave da API (OpenWeatherMap)', 'Ex: abc123def456...');
                    break;
            }

            // Campos comuns
            card += '<div class="row" style="margin-top:10px">';
            card += '<div class="col-sm-4"><label>Duração (ms)</label><input type="number" class="form-control" value="' + (w.duration || 10000) + '" onchange="VetorAdmin.widgets[' + i + '].duration=parseInt(this.value)"><p class="help-block">0 = duração do vídeo</p></div>';
            card += '<div class="col-sm-4"><label>Volume (%)</label><input type="number" class="form-control" value="' + (w.volume != null ? w.volume : 100) + '" min="0" max="100" onchange="VetorAdmin.widgets[' + i + '].volume=parseInt(this.value)"></div>';
            card += '<div class="col-sm-4"><label>Cor de fundo</label><input type="color" class="form-control" value="' + (w.background || '#000000') + '" onchange="VetorAdmin.widgets[' + i + '].background=this.value"></div>';
            card += '</div>';

            card += '</div></div>';
            lista.append(card);
        }
    },

    campoUrl: function(i, w, label, placeholder) {
        return '<div class="form-group"><label>' + label + '</label>' +
            '<input type="text" class="form-control" value="' + VetorAdmin.esc(w.content || '') + '" placeholder="' + placeholder + '" onchange="VetorAdmin.widgets[' + i + '].content=this.value"></div>';
    },

    campoTexto: function(i, w, campo, label, placeholder) {
        return '<div class="form-group"><label>' + label + '</label>' +
            '<input type="text" class="form-control" value="' + VetorAdmin.esc(w[campo] || '') + '" placeholder="' + placeholder + '" onchange="VetorAdmin.widgets[' + i + '].' + campo + '=this.value"></div>';
    },

    esc: function(str) {
        return String(str).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    },

    adicionarWidget: function(tipo) {
        var w = {
            type: tipo, title: '', content: '', active: true,
            duration: (tipo === 'video' || tipo === 'youtube' || tipo === 'iptv') ? 0 : 15000,
            volume: 100, background: '#000000'
        };
        if (tipo === 'comunicado') {
            w.textColor = '#FFFFFF';
            w.fontSize = 4;
            w.background = '#182945';
        }
        if (tipo === 'clima') {
            w.cidade = '';
            w.apiKey = '';
            w.duration = 30000;
            w.background = '#1a1a2e';
        }
        VetorAdmin.widgets.push(w);
        VetorAdmin.renderizar();
    },

    removerWidget: function(index) {
        Swal.fire({
            title: 'Remover widget?',
            text: 'Esta ação não pode ser desfeita',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            confirmButtonText: 'Sim, remover',
            cancelButtonText: 'Cancelar'
        }).then(function(result) {
            if (result.isConfirmed) {
                VetorAdmin.widgets.splice(index, 1);
                VetorAdmin.renderizar();
            }
        });
    },

    moverWidget: function(index, direcao) {
        var novo = index + direcao;
        var temp = VetorAdmin.widgets[index];
        VetorAdmin.widgets[index] = VetorAdmin.widgets[novo];
        VetorAdmin.widgets[novo] = temp;
        VetorAdmin.renderizar();
    },

    salvar: function() {
        SGA.ajax({
            url: SGA.url('salvar'),
            type: 'post',
            data: {
                widgets: JSON.stringify(VetorAdmin.widgets),
                news: JSON.stringify(VetorAdmin.news)
            },
            success: function(response) {
                if (response.success) {
                    Swal.fire({
                        title: 'Salvo!',
                        text: 'Configuração salva com sucesso',
                        icon: 'success',
                        timer: 2000,
                        showConfirmButton: false
                    });
                } else {
                    Swal.fire({ title: 'Erro', text: response.message || 'Erro ao salvar', icon: 'error' });
                }
            }
        });
    },

    upload: function() {
        var input = document.getElementById('input-arquivo');
        if (!input.files || !input.files[0]) {
            Swal.fire({ title: 'Atenção', text: 'Selecione um arquivo', icon: 'warning' });
            return;
        }
        var formData = new FormData();
        formData.append('arquivo', input.files[0]);
        $('#upload-progresso').show();
        $.ajax({
            url: SGA.url('upload'), type: 'POST', data: formData,
            processData: false, contentType: false,
            success: function(response) {
                $('#upload-progresso').hide();
                if (response.success) {
                    Swal.fire({
                        title: 'Enviado!',
                        html: 'URL do arquivo:<br><code>' + response.data.url + '</code>',
                        icon: 'success'
                    });
                    input.value = '';
                    VetorAdmin.carregarArquivos();
                } else {
                    Swal.fire({ title: 'Erro', text: response.message, icon: 'error' });
                }
            },
            error: function() {
                $('#upload-progresso').hide();
                Swal.fire({ title: 'Erro', text: 'Erro ao enviar arquivo', icon: 'error' });
            }
        });
    },

    carregarArquivos: function() {
        SGA.ajax({
            url: SGA.url('listar_arquivos'),
            success: function(response) {
                var tbody = $('#tabela-arquivos tbody');
                tbody.html('');
                if (response.success && response.data) {
                    for (var i = 0; i < response.data.length; i++) {
                        var a = response.data[i];
                        var tam = (a.tamanho / 1024 / 1024).toFixed(2) + ' MB';
                        tbody.append('<tr><td>' + a.nome + '</td><td>' + a.tipo + '</td><td>' + tam + '</td>' +
                            '<td><input type="text" class="form-control input-sm" value="' + a.url + '" onclick="this.select()" readonly></td>' +
                            '<td><button class="btn btn-xs btn-danger" onclick="VetorAdmin.removerArquivo(\'' + a.nome + '\')"><span class="glyphicon glyphicon-trash"></span></button></td></tr>');
                    }
                }
            }
        });
    },

    removerArquivo: function(nome) {
        Swal.fire({
            title: 'Remover arquivo?',
            text: nome,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            confirmButtonText: 'Sim, remover',
            cancelButtonText: 'Cancelar'
        }).then(function(result) {
            if (result.isConfirmed) {
                SGA.ajax({
                    url: SGA.url('remover_arquivo'), type: 'post', data: { nome: nome },
                    success: function() {
                        VetorAdmin.carregarArquivos();
                        Swal.fire({ title: 'Removido!', icon: 'success', timer: 1500, showConfirmButton: false });
                    }
                });
            }
        });
    },

    // ===== Feeds RSS (Rodapé) =====

    renderizarFeeds: function() {
        var lista = $('#news-sources-lista');
        lista.html('');
        if (!VetorAdmin.news.sources) VetorAdmin.news.sources = [];
        $('#news-interval').val(VetorAdmin.news.interval || 10000);

        for (var i = 0; i < VetorAdmin.news.sources.length; i++) {
            var src = VetorAdmin.news.sources[i];
            var card = '<div class="panel panel-default">';
            card += '<div class="panel-body">';
            card += '<div class="row">';
            card += '<div class="col-sm-6">';
            card += '<div class="form-group"><label>URL do Feed RSS</label>';
            card += '<input type="text" class="form-control" value="' + VetorAdmin.esc(src.url || '') + '" placeholder="http://g1.globo.com/dynamo/rss2.xml" onchange="VetorAdmin.news.sources[' + i + '].url=this.value"></div>';
            card += '</div>';
            card += '<div class="col-sm-3">';
            card += '<div class="form-group"><label>Tipo</label>';
            card += '<select class="form-control" onchange="VetorAdmin.news.sources[' + i + '].type=this.value">';
            card += '<option value="rss"' + (src.type === 'rss' ? ' selected' : '') + '>RSS</option>';
            card += '<option value="atom"' + (src.type === 'atom' ? ' selected' : '') + '>Atom</option>';
            card += '</select></div>';
            card += '</div>';
            card += '<div class="col-sm-3">';
            card += '<div class="form-group"><label>&nbsp;</label><br>';
            card += '<button class="btn btn-danger btn-sm" onclick="VetorAdmin.removerFeed(' + i + ')"><span class="glyphicon glyphicon-trash"></span> Remover</button>';
            card += '</div>';
            card += '</div>';
            card += '</div></div></div>';
            lista.append(card);
        }

        if (VetorAdmin.news.sources.length === 0) {
            lista.html('<p class="text-muted" style="padding:15px">Nenhum feed cadastrado. Clique em "Adicionar Feed RSS" para começar.</p>');
        }
    },

    adicionarFeed: function() {
        if (!VetorAdmin.news.sources) VetorAdmin.news.sources = [];
        VetorAdmin.news.sources.push({
            url: 'http://g1.globo.com/dynamo/rss2.xml',
            type: 'rss'
        });
        VetorAdmin.renderizarFeeds();
    },

    removerFeed: function(index) {
        Swal.fire({
            title: 'Remover feed?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            confirmButtonText: 'Sim',
            cancelButtonText: 'Cancelar'
        }).then(function(result) {
            if (result.isConfirmed) {
                VetorAdmin.news.sources.splice(index, 1);
                VetorAdmin.renderizarFeeds();
            }
        });
    }
};

VetorAdmin.renderizar();
VetorAdmin.renderizarFeeds();
VetorAdmin.carregarArquivos();
</script>
{% endblock %}
