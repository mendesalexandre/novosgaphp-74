# =============================================
# NovoSGA - Configuração Nginx
# =============================================
#
# Uso:
#   1. Copie este arquivo:
#      sudo cp nginx.conf.example /etc/nginx/sites-enabled/novosga.conf
#
#   2. Ajuste os caminhos (substitua /var/www/html/novosga pelo caminho real):
#      sudo sed -i "s|/var/www/html/novosga|/seu/caminho|g" /etc/nginx/sites-enabled/novosga.conf
#
#   3. Ajuste server_name se necessário (default: qualquer host com _)
#
#   4. Teste e recarregue:
#      sudo nginx -t && sudo systemctl reload nginx
#
# Requer:
#   - PHP 8.4-FPM rodando (socket /run/php/php8.4-fpm.sock)
#   - PostgreSQL rodando
#   - composer install executado
#   - php bin/install.php executado

server {
    listen 80 default_server;
    server_name _;

    root /var/www/html/novosga/public;
    index index.php index.html;

    client_max_body_size 200M;

    # App principal
    location / {
        try_files $uri $uri/ /index.php$is_args$args;
    }

    # Totem de triagem
    location /totem/ {
        alias /var/www/html/novosga/totem/;
        try_files $uri $uri/ /totem/index.html;
    }

    # Painel web (totem digital)
    location /painel-web/ {
        alias /var/www/html/novosga/painel-web/;
        try_files $uri $uri/ /painel-web/index.html;
    }

    # API
    location /api/ {
        try_files $uri $uri/ /api/index.php$is_args$args;
    }

    # Uploads do vetor panel
    location /modules/vetor.panel/resources/uploads/ {
        alias /var/www/html/novosga/modules/vetor/panel/public/uploads/;
    }

    # PHP-FPM
    location ~ \.php$ {
        fastcgi_pass unix:/run/php/php8.4-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_read_timeout 300;
    }

    # Deny .ht*
    location ~ /\.ht {
        deny all;
    }
}
